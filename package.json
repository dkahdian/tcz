{
	"name": "tcz",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"deploy": "npm run build",
		"stats": "node --import ./scripts/tsx-register.mjs scripts/database-stats.ts",
		"refresh": "node --import ./scripts/tsx-register.mjs scripts/refresh-derived.ts",
		"to-json": "node --import ./scripts/tsx-register.mjs scripts/latex-bijection.ts --to-json",
		"to-latex": "node --import ./scripts/tsx-register.mjs scripts/latex-bijection.ts --to-latex && npm run push-overleaf",
		"latex:roundtrip": "node scripts/latex-roundtrip-check.mjs",
		"push-overleaf": "node --import ./scripts/tsx-register.mjs scripts/push-overleaf.ts",
		"pull-overleaf": "node --import ./scripts/tsx-register.mjs scripts/pull-overleaf.ts"
	},
	"devDependencies": {
		"@sveltejs/adapter-static": "^3.0.1",
		"@sveltejs/kit": "^2.22.0",
		"@sveltejs/vite-plugin-svelte": "^6.0.0",
		"@types/node": "^22.9.0",
		"autoprefixer": "^10.4.21",
		"svelte": "^5.0.0",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^3.4.17",
		"typescript": "^5.0.0",
		"vite": "^7.0.4"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.43.1",
		"cytoscape": "^3.33.1",
		"cytoscape-dagre": "^2.5.0",
		"cytoscape-elk": "^2.3.0",
		"cytoscape-node-edge-html-label": "^1.0.6",
		"elkjs": "^0.11.0",
		"katex": "^0.16.25"
	}
}
